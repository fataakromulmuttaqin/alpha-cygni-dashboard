# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Cache
CACHE_TTL_SECONDS=300
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# External API Keys (optional - using free tiers)
ALPHA_VANTAGE_KEY=
TWELVE_DATA_KEY=

# Data Refresh
DATA_REFRESH_INTERVAL=300
